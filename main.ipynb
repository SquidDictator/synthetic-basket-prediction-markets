   "id": "3b1656c9",
   "metadata": {},
   "source": [
    "# Exploring Synthetic Basket Relationships in Prediction Markets\n",
    "This notebook explores whether relative pricing inconsistencies exist between related contracts in prediction markets. A synthetic basket is constructed to measure deviations between linked contracts and assess whether these deviations contain exploitable structure or reflect differences in how information is incorporated across the market."
   ]
  },
  {
   "cell_type": "markdown",
   "id": "b1068040",
   "metadata": {},
   "source": [
    "# 1. Imports and data setup \n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 11,
   "id": "1b6a8247",
   "metadata": {},
   "outputs": [],
   "source": [
    "import pandas as pd\n",
    "import matplotlib.pyplot as plt\n",
    "import numpy as np\n",
    "import os\n",
    "\n",
    "df = pd.read_csv(\"AllTop4Data.csv\")\n",
    "df[\"timestamp\"] = pd.to_datetime(df[\"timestamp\"])\n",
    "df = df.sort_values(\"timestamp\").set_index(\"timestamp\")\n",
    "os.makedirs(\"results\", exist_ok=True)\n"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "f405ca48",
   "metadata": {},
   "source": [
    "# 2. Strategy parameters"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 12,
   "id": "e58154a0",
   "metadata": {},
   "outputs": [],
   "source": [
    "SHOW_TRADE_LOG = False\n",
    "ENTRY_THRESH = 1.5\n",
    "EXIT_THRESH = 0.5\n",
    "STARTING_BANKROLL = 1000\n",
    "STAKE_PER_POINT = 10\n",
    "BASE_SLIPPAGE_PTS = 0.20\n",
    "COMMISSION_PER_SIDE = 0.30\n",
    "ROLLING_WINDOW = 200\n",
    "VOL_WINDOW = 50"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "2186f47e",
   "metadata": {},
   "source": [
    "# 3. Core backtest function "
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 13,
   "id": "9153a5b5",
   "metadata": {},
   "outputs": [],
   "source": [
    "def run_backtest(target, basket_teams, df):\n",
    "    cols = basket_teams + [target]\n",
    "    hourly = df[cols].resample(\"h\").mean().ffill().copy()\n",
    "\n",
    "    # Build basket and spread\n",
    "    hourly[\"Basket\"] = hourly[basket_teams].mean(axis=1)\n",
    "    hourly[\"spread\"] = hourly[target] - hourly[\"Basket\"]\n",
    "\n",
    "    # Z-score\n",
    "    hourly[\"spread_mean\"] = hourly[\"spread\"].rolling(ROLLING_WINDOW).mean().shift(1)\n",
    "    hourly[\"spread_std\"] = hourly[\"spread\"].rolling(ROLLING_WINDOW).std().shift(1)\n",
    "    hourly[\"zscore\"] = (hourly[\"spread\"] - hourly[\"spread_mean\"]) / hourly[\"spread_std\"]\n",
    "\n",
    "    # Volatility for simple dynamic slippage\n",
    "    hourly[\"spread_vol\"] = hourly[\"spread\"].rolling(VOL_WINDOW).std().shift(1)\n",
    "    avg_vol = hourly[\"spread_vol\"].mean()\n",
    "\n",
    "    # Signals\n",
    "    hourly[\"signal\"] = 0.0\n",
    "    hourly.loc[hourly[\"zscore\"] >= ENTRY_THRESH, \"signal\"] = -1.0\n",
    "    hourly.loc[hourly[\"zscore\"] <= -ENTRY_THRESH, \"signal\"] = 1.0\n",
    "    hourly.loc[hourly[\"zscore\"].abs() < EXIT_THRESH, \"signal\"] = 0.0\n",
    "    hourly[\"signal_exec\"] = hourly[\"signal\"].shift(1).fillna(0.0)\n",
    "\n",
    "    # State variables\n",
    "    current_pos = 0.0\n",
    "    current_bank = STARTING_BANKROLL\n",
    "    entry_time = None\n",
    "    entry_spread = None\n",
    "\n",
    "    bankroll = np.full(len(hourly), STARTING_BANKROLL)\n",
    "    positions = np.zeros(len(hourly))\n",
    "    trades_log = []\n",
    "\n",
    "    spreads = hourly[\"spread\"].values\n",
    "    signals = hourly[\"signal_exec\"].values\n",
    "    vols = hourly[\"spread_vol\"].values\n",
    "    times = hourly.index\n",
    "\n",
    "    total_commission = 0.0\n",
    "    total_slippage = 0.0\n",
    "\n",
    "    def get_trade_cost(vol_val):\n",
    "        \"\"\"Simple round-trip cost model with flat commission and dynamic slippage.\"\"\"\n",
    "        vol_used = vol_val if not np.isnan(vol_val) else avg_vol\n",
    "        vol_ratio = vol_used / avg_vol if avg_vol > 0 else 1.0\n",
    "\n",
    "        slippage_per_side = BASE_SLIPPAGE_PTS * max(1.0, vol_ratio) * STAKE_PER_POINT\n",
    "        commission_per_side = COMMISSION_PER_SIDE\n",
    "\n",
    "        round_trip_cost = 2 * (commission_per_side + slippage_per_side)\n",
    "        round_trip_commission = 2 * commission_per_side\n",
    "        round_trip_slippage = 2 * slippage_per_side\n",
    "\n",
    "        return round_trip_cost, round_trip_commission, round_trip_slippage\n",
    "\n",
    "    for i in range(1, len(hourly)):\n",
    "        spr = spreads[i]\n",
    "        sig = signals[i]\n",
    "        vol = vols[i]\n",
    "\n",
    "        # Close or flip\n",
    "        if current_pos != 0.0 and (sig == 0.0 or np.sign(sig) != np.sign(current_pos)):\n",
    "            exit_time = times[i]\n",
    "            spread_move = spr - entry_spread\n",
    "            gross_pnl = current_pos * spread_move * STAKE_PER_POINT\n",
    "\n",
    "            trade_cost, comm_cost, slip_cost = get_trade_cost(vol)\n",
    "            net_pnl = gross_pnl - trade_cost\n",
    "\n",
    "            trades_log.append({\n",
    "                \"Target\": target,\n",
    "                \"Basket\": \"+\".join(basket_teams),\n",
    "                \"Entry_Time\": entry_time,\n",
    "                \"Exit_Time\": exit_time,\n",
    "                \"Direction\": \"Long\" if current_pos > 0 else \"Short\",\n",
    "                \"Entry_Spread\": round(entry_spread, 4),\n",
    "                \"Exit_Spread\": round(spr, 4),\n",
    "                \"Gross_PnL_£\": round(gross_pnl, 2),\n",
    "                \"Commission_£\": round(comm_cost, 2),\n",
    "                \"Slippage_£\": round(slip_cost, 2),\n",
    "                \"Net_PnL_£\": round(net_pnl, 2)\n",
    "            })\n",
    "\n",
    "            current_bank += net_pnl\n",
    "            total_commission += comm_cost\n",
    "            total_slippage += slip_cost\n",
    "\n",
    "            # Flip into new position if needed\n",
    "            current_pos = sig if sig != 0.0 else 0.0\n",
    "            if current_pos != 0.0:\n",
    "                entry_time = times[i]\n",
    "                entry_spread = spr\n",
    "            else:\n",
    "                entry_time = None\n",
    "                entry_spread = None\n",
    "\n",
    "        # Open from flat\n",
    "        elif current_pos == 0.0 and sig != 0.0:\n",
    "            current_pos = sig\n",
    "            entry_time = times[i]\n",
    "            entry_spread = spr\n",
    "\n",
    "        bankroll[i] = current_bank\n",
    "        positions[i] = current_pos\n",
    "\n",
    "    # Force close final open trade\n",
    "    if current_pos != 0.0 and entry_spread is not None:\n",
    "        final_spr = spreads[-1]\n",
    "        final_time = times[-1]\n",
    "        final_vol = vols[-1]\n",
    "\n",
    "        spread_move = final_spr - entry_spread\n",
    "        gross_pnl = current_pos * spread_move * STAKE_PER_POINT\n",
    "        trade_cost, comm_cost, slip_cost = get_trade_cost(final_vol)\n",
    "        net_pnl = gross_pnl - trade_cost\n",
    "\n",
    "        trades_log.append({\n",
    "            \"Target\": target,\n",
    "            \"Basket\": \"+\".join(basket_teams),\n",
    "            \"Entry_Time\": entry_time,\n",
    "            \"Exit_Time\": final_time,\n",
    "            \"Direction\": \"Long\" if current_pos > 0 else \"Short\",\n",
    "            \"Entry_Spread\": round(entry_spread, 4),\n",
    "            \"Exit_Spread\": round(final_spr, 4),\n",
    "            \"Gross_PnL_£\": round(gross_pnl, 2),\n",
    "            \"Commission_£\": round(comm_cost, 2),\n",
    "            \"Slippage_£\": round(slip_cost, 2),\n",
    "            \"Net_PnL_£\": round(net_pnl, 2)\n",
    "        })\n",
    "\n",
    "        current_bank += net_pnl\n",
    "        total_commission += comm_cost\n",
    "        total_slippage += slip_cost\n",
    "        bankroll[-1] = current_bank\n",
    "        positions[-1] = 0.0\n",
    "\n",
    "    hourly[\"Position\"] = positions\n",
    "    hourly[\"Bankroll\"] = bankroll\n",
    "\n",
    "    # Metrics\n",
    "    if trades_log:\n",
    "        trades_df = pd.DataFrame(trades_log)\n",
    "\n",
    "        wins = trades_df.loc[trades_df[\"Net_PnL_£\"] > 0, \"Net_PnL_£\"].sum()\n",
    "        losses = abs(trades_df.loc[trades_df[\"Net_PnL_£\"] < 0, \"Net_PnL_£\"].sum())\n",
    "        pf = wins / losses if losses > 0 else np.inf\n",
    "        wr = (trades_df[\"Net_PnL_£\"] > 0).mean() * 100\n",
    "\n",
    "        max_dd = (\n",
    "            (hourly[\"Bankroll\"] - hourly[\"Bankroll\"].cummax()) /\n",
    "            hourly[\"Bankroll\"].cummax()\n",
    "        ).min() * 100\n",
    "\n",
    "        hourly_ret = hourly[\"Bankroll\"].pct_change().dropna()\n",
    "        sharpe = (\n",
    "            (hourly_ret.mean() / hourly_ret.std()) * np.sqrt(24 * 30)\n",
    "            if hourly_ret.std() > 0 else 0.0\n",
    "        )\n",
    "\n",
    "        gross_profit = trades_df[\"Gross_PnL_£\"].sum()\n",
    "        net_profit = trades_df[\"Net_PnL_£\"].sum()\n",
    "    else:\n",
    "        trades_df = pd.DataFrame()\n",
    "        pf = wr = max_dd = sharpe = 0.0\n",
    "        gross_profit = net_profit = 0.0\n",
    "\n",
    "    # Plot\n",
    "    fig, (ax1, ax2) = plt.subplots(\n",
    "        2, 1, figsize=(14, 9), sharex=True,\n",
    "        gridspec_kw={\"height_ratios\": [1, 1]}\n",
    "    )\n",
    "\n",
    "    ax1.plot(hourly.index, hourly[target], label=target, linewidth=1.5, alpha=0.8)\n",
    "    ax1.plot(\n",
    "        hourly.index,\n",
    "        hourly[\"Basket\"],\n",
    "        label=f'Basket ({\"+\".join(basket_teams)})',\n",
    "        color=\"black\",\n",
    "        linewidth=2,\n",
    "        alpha=0.8\n",
    "    )\n",
    "    ax1.set_ylabel(\"Price / Probability\")\n",
    "    ax1.legend()\n",
    "    ax1.grid(alpha=0.3)\n",
    "\n",
    "    ax2.plot(hourly.index, hourly[\"Bankroll\"], color=\"purple\", linewidth=2.5)\n",
    "    ax2.axhline(STARTING_BANKROLL, color=\"gray\", linestyle=\"--\", alpha=0.5)\n",
    "    ax2.set_ylabel(\"Bankroll (£)\")\n",
    "    ax2.grid(alpha=0.3)\n",
    "\n",
    "    plt.xticks(rotation=45)\n",
    "    plt.tight_layout()\n",
    "\n",
    "    safe_name = target.replace(\" \", \"_\")\n",
    "    plt.savefig(f\"results/{safe_name}_backtest.png\", dpi=200, bbox_inches=\"tight\")\n",
    "    plt.close()\n",
    "\n",
    "    if SHOW_TRADE_LOG and not trades_df.empty:\n",
    "        print(f\"\\n{target} TRADE LOG\")\n",
    "        print(trades_df.head(5).to_string(index=False))\n",
    "        if len(trades_df) > 8:\n",
    "            print(\"...\")\n",
    "            print(trades_df.tail(3).to_string(index=False))\n",
    "\n",
    "    return {\n",
    "        \"Target\": target,\n",
    "        \"Basket\": \"+\".join(basket_teams),\n",
    "        \"Gross_Profit_£\": round(gross_profit, 2),\n",
    "        \"Commission_£\": round(total_commission, 2),\n",
    "        \"Slippage_£\": round(total_slippage, 2),\n",
    "        \"Total_Costs_£\": round(total_commission + total_slippage, 2),\n",
    "        \"Net_Profit_£\": round(net_profit, 2),\n",
    "        \"Return_%\": round((current_bank / STARTING_BANKROLL - 1) * 100, 1),\n",
    "        \"Win_Rate_%\": round(wr, 1),\n",
    "        \"Profit_Factor\": round(pf, 2),\n",
    "        \"Max_Drawdown_%\": round(max_dd, 1),\n",
    "        \"Sharpe_Month\": round(sharpe, 2),\n",
    "        \"Total_Trades\": len(trades_log)\n",
    "    }, trades_df"
   ]
  },
  {
