   "source": [
    "# 4. Run All Setups"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 14,
   "id": "f03cdc12",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Running all team setups...\n",
      "\n",
      "Testing: Aston Villa vs [Man Utd+Chelsea]\n",
      "\n",
      "Testing: Man Utd vs [Aston Villa+Chelsea]\n",
      "\n",
      "Testing: Chelsea vs [Aston Villa+Man Utd]\n"
     ]
    }
   ],
   "source": [
    "print(\"Running all team setups...\")\n",
    "teams = [\"Aston Villa\", \"Man Utd\", \"Chelsea\"]\n",
    "all_results = []\n",
    "\n",
    "for target in teams:\n",
    "    basket = [t for t in teams if t != target]\n",
    "    print(f\"\\nTesting: {target} vs [{'+'.join(basket)}]\")\n",
    "    res, trades_df = run_backtest(target, basket, df)\n",
    "    all_results.append(res)\n"
    "    all_trades.append(trades_df)\n"
    "all_trades_df = pd.concat(all_trades, ignore_index=True)\n"
    "all_trades_df.to_csv("results/trades_log.csv", index=False)\n"
    "pd.DataFrame(all_results).to_csv("results/summary.csv", index=False)\n"
   ]
  },
